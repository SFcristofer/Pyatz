Quote q = [SELECT Id FROM Quote LIMIT 1]; List<Map<String, Object>> data = new List<Map<String, Object>>{ new Map<String, Object>{'anio' => 2024, 'costo' => 1000, 'margen' => 30, 'indirecto' => 5, 'comision1' => 3, 'comision2' => 2, 'regalia' => 1, 'dias' => 30, 'isr' => 30, 'ru' => 10} }; try { QuoteController.savePLAnalysis(q.Id, JSON.serialize(data)); } catch (Exception e) { System.debug('ERROR: ' + e.getMessage()); }
