<?xml version="1.0" encoding="UTF-8"?>
<LightningMessageChannel xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Canal de comunicación para sincronizar los módulos del Desarrollo 360 de Pyatz.</description>
    <isExposed>true</isExposed>
    <lightningMessageFields>
        <description>ID del registro principal (Opportunity/Expediente)</description>
        <fieldName>recordId</fieldName>
    </lightningMessageFields>
    <lightningMessageFields>
        <description>Fase actual del desarrollo</description>
        <fieldName>phase</fieldName>
    </lightningMessageFields>
    <lightningMessageFields>
        <description>Estado de la operación (Updated, Completed, etc.)</description>
        <fieldName>status</fieldName>
    </lightningMessageFields>
    <masterLabel>Operations360Channel</masterLabel>
</LightningMessageChannel>
