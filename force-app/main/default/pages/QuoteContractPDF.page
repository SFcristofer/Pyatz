<apex:page standardController="Quote" extensions="QuoteContractPDFController" renderAs="pdf" showHeader="false" sidebar="false"
    standardStylesheets="false" applyBodyTag="false" applyHtmlTag="false" cache="false">
    <html>

    <head>
        <style type="text/css">
            @page {
                size: letter;
                margin: 0cm 0 0cm 0;

                /* @bottom-right {
                    content: "Página " counter(page) " de " counter(pages);
                    font-family: 'Helvetica', 'Arial', sans-serif;
                    font-size: 8pt;
                    color: #666;
                    padding-right: 20pt;
                    vertical-align: top;
                    padding-top: 10pt;
                }  */
            }

            body {
                font-family: 'Helvetica', 'Arial', sans-serif;
                font-size: 10pt;
                color: #333;
                line-height: 1.3;
                margin: 0 2cm 2cm 2cm;
                padding: 0;
            }

            .header-img {
                width: 100%;
                margin-bottom: 10pt;
                display: block;
                position: fixed;
                top: 0;
                left: 0;
                z-index: 1000;
            }

            .footer-img {
                width: 100%;
                position: fixed;
                bottom: 0;
                left: 0;
                display: block;
                height: 1.5cm;
                z-index: 1000;
                pointer-events: none;
            }

            .watermark {
                position: fixed;
                top: 30%;
                /* left: 20%; */
                /* transform: translate(-50%, -50%); */
                width: 100%;
                height: auto;
                /* opacity: 0.1; */
                z-index: -1;
                pointer-events: none;
            }

            .content-body {
                padding: 2cm 20pt 2cm 20pt;
                margin-top: 3cm;
                margin-bottom: 3cm;
                page-break-inside: auto;
            }

            .title-contract {
                font-size: 16pt;
                font-weight: bold;
                margin-bottom: 2pt;
                color: #000;
                text-transform: uppercase;
            }

            .line-business {
                font-size: 11pt;
                color: #333;
                margin-bottom: 12pt;
                font-weight: normal;
            }

            /* TABLA CON DISEÑO FIJO */
            .table-services {
                width: 100%;
                border-collapse: collapse;
                margin-top: 15pt;
                table-layout: fixed;
            }

            .table-services th {
                background-color: #D4EDDA;
                color: #333;
                padding: 8pt;
                border: 0.5pt solid #fff;
                text-align: center;
                font-size: 9pt;
            }

            .table-services td {
                padding: 8pt;
                border-bottom: 0.5pt solid #eee;
                vertical-align: top;
                word-wrap: break-word;
                overflow: hidden;
            }

            .totals-box {
                width: 300pt;
                float: right;
                margin-top: 10pt;
                page-break-inside: avoid;
            }

            .grand-total {
                font-size: 12pt;
                color: #0070d2;
                border-bottom: 2pt solid #0070d2;
                font-weight: bold;
            }

            .signature-section {
                margin-top: 50pt;
                width: 100%;
                page-break-inside: avoid;
            }

            .sig-box {
                width: 45%;
                text-align: center;
                display: inline-block;
                vertical-align: bottom;
            }

            .sig-line {
                border-top: 1px solid #333;
                margin: 0 20pt;
                padding-top: 5pt;
                font-size: 9pt;
            }

            .spacer {
                width: 8%;
                display: inline-block;
            }

            .intro-text {
                margin-top: 20pt;
                text-align: justify;
                white-space: pre-wrap;
                display: block;
                line-height: 1.5;
                page-break-inside: auto;
            }

            .page-break-before {
                page-break-before: always;
            }

            .page-break-after {
                page-break-after: always;
            }

            .avoid-break {
                page-break-inside: avoid;
            }
        </style>
    </head>

    <body>
        <img src="{!$Resource.WatermarPDF}" class="watermark" />
        <img src="{!$Resource.HeaderPDF}" class="header-img" />

        <div class="content-body">
            <div class="title-contract">CONTRATO DE SERVICIOS No. {!quoteRecord.QuoteNumber}</div>
            <div class="line-business">{!quoteRecord.Business_Lines_Selected__c}</div>

            <div style="margin-top: 5pt; font-size: 10pt;">
                <div><strong>Agente Responsable:</strong> {!firmanteNombre}</div>
                <div><strong>Fecha:</strong> {!fechaHoy}</div>
            </div>

            <div style="font-size: 14pt; font-weight: bold; margin-top: 15pt;">{!quoteRecord.Account.Name}</div>
            <div style="font-size: 11pt; margin-top: 5pt;"><strong>Sede:</strong> {!quoteRecord.Technical_Sedes__c}</div>

            <div class="intro-text">
                <apex:outputText value="{!IF(NOT(ISBLANK(quoteRecord.Introduction_Text__c)), quoteRecord.Introduction_Text__c, quoteRecord.Description)}"
                    escape="false" />
            </div>

            <div style="font-size: 12pt; font-weight: bold; margin-top: 20pt; color: #0070d2;">Servicios Contratados</div>

            <table class="table-services">
                <thead>
                    <tr>
                        <th width="{!IF(config['show_line_prices'], '45%', '85%')}">CONCEPTO / DESCRIPCIÓN</th>
                        <th width="15%">CANTIDAD</th>
                        <apex:outputPanel rendered="{!config['show_line_prices']}" layout="none">
                            <th width="20%">P. UNITARIO</th>
                            <th width="20%">IMPORTE (C/IVA)</th>
                        </apex:outputPanel>
                    </tr>
                </thead>
                <tbody>
                    <apex:repeat value="{!selectedLineItems}" var="item">
                        <tr>
                            <td>
                                <strong>{!item.Product2.Name}</strong><br />
                                <span style="font-size: 8pt; color: #666; display: block; margin-top: 3pt;">
                                    <apex:outputText value="{!item.Description}" escape="false" />
                                </span>
                            </td>
                            <td align="center" style="vertical-align: middle;">{!item.Quantity}</td>
                            <apex:outputPanel rendered="{!config['show_line_prices']}" layout="none">
                                <td align="right" style="vertical-align: middle;">
                                    <apex:outputText value="{0, number, currency}">
                                        <apex:param value="{!item.UnitPrice}" />
                                    </apex:outputText>
                                </td>
                                <td align="right" style="vertical-align: middle;">
                                    <strong>
                                        <apex:outputText value="{0, number, currency}">
                                            <apex:param value="{!item.TotalPrice * 1.16}" />
                                        </apex:outputText>
                                    </strong>
                                </td>
                            </apex:outputPanel>
                        </tr>
                    </apex:repeat>
                </tbody>
            </table>

            <apex:outputPanel rendered="{!config['show_total']}">
                <div class="totals-box">
                    <table style="width: 100%; border-collapse: collapse;">
                        <tr>
                            <td style="padding: 3pt 0; text-align: left; color: #666; font-size: 9pt;">SUBTOTAL</td>
                            <td style="padding: 3pt 0; text-align: right; font-weight: bold; width: 80pt;">
                                <apex:outputText value="{0, number, currency}">
                                    <apex:param value="{!quoteRecord.Subtotal}" />
                                </apex:outputText>
                            </td>
                        </tr>
                        <apex:outputPanel rendered="{!NOT(ISNULL(quoteRecord.Discount)) && quoteRecord.Discount > 0}" layout="none">
                            <tr>
                                <td style="padding: 3pt 0; text-align: left; color: #d8000c; font-size: 9pt;">DESCUENTO</td>
                                <td style="padding: 3pt 0; text-align: right; font-weight: bold; color: #d8000c;">
                                    - <apex:outputText value="{0, number, currency}">
                                        <apex:param value="{!quoteRecord.Discount}" />
                                    </apex:outputText>
                                </td>
                            </tr>
                        </apex:outputPanel>
                        <tr>
                            <td style="padding: 3pt 0; text-align: left; color: #666; font-size: 9pt;">I.V.A. (16%)</td>
                            <td style="padding: 3pt 0; text-align: right; font-weight: bold;">
                                <apex:outputText value="{0, number, currency}">
                                    <apex:param value="{!totalContrato - (quoteRecord.Subtotal - IF(ISNULL(quoteRecord.Discount), 0, quoteRecord.Discount))}" />
                                </apex:outputText>
                            </td>
                        </tr>
                        <tr>
                            <td style="padding: 8pt 0; text-align: left; font-size: 12pt; font-weight: bold; color: #0070d2;">TOTAL DEL CONTRATO</td>
                            <td style="padding: 8pt 0; text-align: right; font-size: 12pt; font-weight: bold; color: #0070d2; border-bottom: 2pt solid #0070d2;">
                                <apex:outputText value="{0, number, currency}">
                                    <apex:param value="{!totalContrato}" />
                                </apex:outputText>
                            </td>
                        </tr>
                    </table>
                </div>
            </apex:outputPanel>

            <div style="clear: both;"></div>

            <div class="page-break-before"></div>

            <div class="signature-section">
                <div class="sig-box">
                    <div class="sig-line">EL CLIENTE (FIRMA)</div>
                    <div style="font-size: 8pt; margin-top: 5pt; font-weight: bold; text-transform: uppercase;">{!firmanteCliente}</div>
                </div>
                <div class="spacer"></div>
                <div class="sig-box">
                    <div style="margin-bottom: 10pt;">
                        <div style="font-family: cursive; font-size: 18pt; color: #0070d2;">{!firmanteNombre}</div>
                    </div>
                    <div class="sig-line">
                        POR PYATZ: {!firmanteNombre}<br />
                        {!firmanteCargo}
                    </div>
                </div>
            </div>
            <img src="{!$Resource.FooterPDF}" class="footer-img" />
        </div>

        
    </body>

    </html>
</apex:page>