<apex:page standardController="Quote" extensions="QuoteTechnicalPDFController" renderAs="pdf" showHeader="false" sidebar="false" standardStylesheets="false" applyBodyTag="false" applyHtmlTag="false">
    <html>
        <head>
            <style type="text/css">
                @page { 
                    size: letter; 
                    margin: 0cm 0 0cm 0; 
                }
                
            body {
                font-family: 'Helvetica', 'Arial', sans-serif;
                font-size: 10pt;
                color: #333;
                line-height: 1.3;
                margin: 0;
                padding: 0;
            }

            .header-img {
                width: 100%;
                margin-bottom: 10pt;
                display: block;
                position: fixed;
                top: 0;
                left: 0;
                z-index: 1000;
            }

            .footer-img {
                width: 100%;
                position: fixed;
                bottom: 0;
                left: 0;
                display: block;
                height: 1.5cm;
                z-index: 1000;
                pointer-events: none;
            }

            .watermark {
                position: fixed;
                top: 30%;
                width: 100%;
                height: auto;
                z-index: -1;
                pointer-events: none;
            }

            .content-body {
                padding: 2cm 20pt 2cm 20pt;
                margin-top: 1.5cm;
                margin-bottom: 1.5cm;
            }

                /* TABLAS ESTRUCTURALES */
                table { width: 100%; border-collapse: collapse; table-layout: fixed; }
                
                .table-services { width: 100%; border-collapse: collapse; margin-top: 15pt; }
                .table-services th { background-color: #D4EDDA; padding: 8pt; border-bottom: 1.5pt solid #0070d2; font-size: 8pt; text-align: center; text-transform: uppercase; }
                
                /* Fila Comercial */
                .row-commercial td { padding: 8pt 5pt; vertical-align: middle; font-size: 10pt; background-color: #fff; }
                
                /* Fila de Detalle Técnico (Expandida) */
                .row-technical-detail td { 
                    padding: 5pt 15pt 15pt 15pt; 
                    border-bottom: 0.5pt solid #eee; 
                    font-size: 9pt; 
                    color: #444; 
                    line-height: 1.4;
                }
                
                .separator-row td { background-color: #f1f5f9; font-weight: bold; color: #0070d2; padding: 10pt; border-top: 2pt solid #0070d2; }

                .totals-box { width: 220pt; margin-left: auto; margin-top: 10pt; }
                .grand-total { font-size: 13pt; color: #0070d2; font-weight: bold; border-top: 1.5pt solid #0070d2; padding-top: 8pt; }

                .signature-section { margin-top: 50pt; width: 100%; page-break-inside: avoid; }
                .sig-box { width: 33.3%; text-align: center; display: inline-block; vertical-align: top; }
                .sig-line { border-top: 1pt solid #333; margin: 0 20pt; padding-top: 5pt; font-size: 8.5pt; }

                .rich-text-content { text-align: left; display: block; width: 100%; }
                /* Asegurar que las imágenes dentro del texto no rompan el PDF */
                .rich-text-content img { max-width: 100% !important; height: auto !important; }

                .page-number { text-align: right; font-size: 8pt; color: #999; margin-top: 20pt; }
            </style>
        </head>
        <body>
            <img src="{!$Resource.HeaderPDF}" class="header-img" />
            <img src="{!$Resource.WatermarPDF}" class="watermark" />

            <div class="content-body">
                <!-- CABECERA -->
                <table width="100%">
                    <tr>
                        <td width="65%">
                            <div style="font-size: 22pt; font-weight: bold;">PRESUPUESTO No. {!technicalQuote.QuoteNumber}</div>
                            <div style="font-size: 13pt; color: #0070d2; font-weight: bold; margin-top: 5pt;">{!technicalQuote.Business_Lines_Selected__c}</div>
                        </td>
                        <td width="35%" align="right" style="font-size: 10pt;">
                            <div><strong>Fecha:</strong> <apex:outputText value="{0,date,dd/MM/yyyy}"><apex:param value="{!technicalQuote.CreatedDate}" /></apex:outputText></div>
                            <div><strong>Agente:</strong> {!technicalQuote.CreatedBy.Name}</div>
                        </td>
                    </tr>
                </table>

                <div style="font-size: 16pt; font-weight: bold; margin-top: 30pt; border-bottom: 1pt solid #eee; padding-bottom: 5pt;">{!technicalQuote.Technical_Sedes__c}</div>
                <div style="margin-top: 10pt; font-size: 11pt;"><strong>Asunto:</strong> {!technicalQuote.Name}</div>

                <!-- INTRODUCCIÓN -->
                <apex:outputPanel rendered="{!NOT(ISBLANK(technicalQuote.Introduction_Text__c))}">
                    <div class="rich-text-content" style="margin-top: 15pt;">
                        <apex:outputText value="{!technicalQuote.Introduction_Text__c}" escape="false"/>
                    </div>
                </apex:outputPanel>

                <!-- TABLA DE SERVICIOS INTEGRADA -->
                <table class="table-services">
                    <thead>
                        <tr>
                            <th width="50%">CONCEPTO / SERVICIO</th>
                            <th width="10%">CANT</th>
                            <th width="20%">P. UNITARIO</th>
                            <th width="20%">IMPORTE</th>
                        </tr>
                    </thead>
                    <tbody>
                        <apex:repeat value="{!technicalQuote.QuoteLineItems}" var="item">
                            <!-- CASO 1: SEPARADOR -->
                            <apex:outputPanel rendered="{!BLANKVALUE(item.Quantity, 0) == 0}" layout="none">
                                <tr class="separator-row">
                                    <td colspan="4"><strong>{!item.Product2.Name}</strong></td>
                                </tr>
                            </apex:outputPanel>

                            <!-- CASO 2: PARTIDA COMERCIAL + DETALLE TÉCNICO -->
                            <apex:outputPanel rendered="{!BLANKVALUE(item.Quantity, 0) > 0}" layout="none">
                                <!-- FILA A: DATOS COMERCIALES -->
                                <tr class="row-commercial">
                                    <td><strong>{!item.Product2.Name}</strong></td>
                                    <td align="center">{!item.Quantity}</td>
                                    <td align="right"><apex:outputText value="{0, number, currency}"><apex:param value="{!BLANKVALUE(item.UnitPrice, 0)}" /></apex:outputText></td>
                                    <td align="right"><apex:outputText value="{0, number, currency}"><apex:param value="{!BLANKVALUE(item.TotalPrice, 0)}" /></apex:outputText></td>
                                </tr>
                                <!-- FILA B: DETALLE TÉCNICO EXPANDIDO (Si existe descripción) -->
                                <apex:outputPanel rendered="{!NOT(ISBLANK(item.Descripcion_Detallada__c))}" layout="none">
                                    <tr class="row-technical-detail">
                                        <td colspan="4">
                                            <div class="rich-text-content" style="border-left: 2pt solid #eee; padding-left: 10pt;">
                                                <apex:outputText value="{!item.Descripcion_Detallada__c}" escape="false" />
                                            </div>
                                        </td>
                                    </tr>
                                </apex:outputPanel>
                            </apex:outputPanel>
                        </apex:repeat>
                    </tbody>
                </table>

                <!-- TOTALES -->
                <div class="totals-box">
                    <table width="100%">
                        <tr>
                            <td align="right" style="font-weight: bold; color: #666; padding: 5pt;">SUBTOTAL</td>
                            <td align="right" width="80pt" style="border-bottom: 0.5pt solid #eee;">
                                <apex:outputText value="{0, number, currency}"><apex:param value="{!BLANKVALUE(technicalQuote.Subtotal, 0)}" /></apex:outputText>
                            </td>
                        </tr>
                        <tr>
                            <td align="right" style="font-weight: bold; color: #666; padding: 5pt;">I.V.A. (16%)</td>
                            <td align="right" style="border-bottom: 0.5pt solid #eee;">
                                <apex:outputText value="{0, number, currency}"><apex:param value="{!BLANKVALUE(technicalQuote.Tax, 0)}" /></apex:outputText>
                            </td>
                        </tr>
                        <tr class="grand-total">
                            <td align="right" style="padding: 10pt 5pt;">TOTAL</td>
                            <td align="right">
                                <apex:outputText value="{0, number, currency}"><apex:param value="{!BLANKVALUE(technicalQuote.TotalPrice, 0)}" /></apex:outputText>
                            </td>
                        </tr>
                    </table>
                </div>

                <!-- DATOS DE PAGO -->
                <div style="margin-top: 25pt; border: 1pt solid #ccc; page-break-inside: avoid;">
                    <div style="background-color: #0070d2; color: white; padding: 5pt; text-align: center; font-weight: bold; text-transform: uppercase;">Condiciones de Pago</div>
                    <table width="100%">
                        <tr>
                            <td width="30%" align="center" style="border-right: 1pt solid #ccc; background-color: #f9f9f9; vertical-align: middle; font-weight: bold;">Transferencia / Depósito</td>
                            <td width="70%" style="padding: 10pt; text-align: justify;">
                                <apex:outputText value="{!technicalQuote.Description}" escape="false" />
                            </td>
                        </tr>
                    </table>
                </div>

                <!-- CONDICIONES / CLAUSULAS -->
                <apex:outputPanel rendered="{!NOT(ISBLANK(technicalQuote.Warranty_Text__c))}">
                    <div style="margin-top: 30pt; border-top: 1.5pt solid #0070d2; padding-top: 15pt;">
                        <div style="font-weight: bold; font-size: 11pt; margin-bottom: 8pt; text-transform: uppercase;">Condiciones / Anexos / Cláusulas</div>
                        <div class="rich-text-content" style="font-size: 9.5pt;">
                            <apex:outputText escape="false" value="{!technicalQuote.Warranty_Text__c}" />
                        </div>
                    </div>
                </apex:outputPanel>

                <!-- FIRMAS -->
                <div class="signature-section">
                    <table width="100%">
                        <tr>
                            <td width="33%" align="center">
                                <div style="height: 70pt;"></div>
                                <div class="sig-line">Firma del CLIENTE</div>
                            </td>
                            <td width="33%" align="center">
                                <div style="height: 70pt; vertical-align: bottom; padding-bottom: 5pt;">
                                    <apex:outputPanel rendered="{!NOT(ISBLANK(signatureUrl))}" layout="none">
                                        <img src="{!signatureUrl}" style="height: 55pt; width: auto;" />
                                    </apex:outputPanel>
                                    <apex:outputPanel rendered="{!ISBLANK(signatureUrl)}" layout="none">
                                        <div style="font-family: 'Courier New', monospace; font-size: 14pt; color: #0070d2;">{!technicalQuote.CreatedBy.Name}</div>
                                    </apex:outputPanel>
                                </div>
                                <div class="sig-line">FIRMA AUTORIZADA PYATZ</div>
                            </td>
                            <td width="33%" align="center">
                                <div style="border: 1pt solid #ccc; width: 60pt; height: 60pt; border-radius: 50%; margin: 0 auto 8pt auto; line-height: 60pt; font-size: 8pt; color: #bbb;">SELLO</div>
                                <div class="sig-line">Sello de la Empresa</div>
                            </td>
                        </tr>
                    </table>
                </div>
                
                <div class="page-number">Página <span class="pagenumber"/> de <span class="pagecount"/></div>
            </div>
            <img src="{!$Resource.FooterPDF}" class="footer-img" />
        </body>
    </html>
</apex:page>