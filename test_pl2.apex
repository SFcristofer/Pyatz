List<Object> data = (List<Object>)JSON.deserializeUntyped('[{"anio": 2024, "costo": 1000, "margen": 30, "indirecto": 5, "comision1": 3, "comision2": 2, "regalia": 1, "dias": 30, "isr": 30, "ru": 10}]'); List<Analisis_PL__c> toUpsert = new List<Analisis_PL__c>(); Quote q = [SELECT Id FROM Quote LIMIT 1]; for (Object obj : data) { Map<String, Object> row = (Map<String, Object>)obj; Integer anio = Integer.valueOf(row.get('anio')); Analisis_PL__c pl = new Analisis_PL__c( Presupuesto__c = q.Id, Anio__c = anio, Costo_Inversion__c = Decimal.valueOf(String.valueOf(row.get('costo'))), Margen_Esperado__c = Decimal.valueOf(String.valueOf(row.get('margen'))), Gastos_Indirectos__c = Decimal.valueOf(String.valueOf(row.get('indirecto'))), Comision_Venta__c = Decimal.valueOf(String.valueOf(row.get('comision1'))), Comision_Venta_2__c = Decimal.valueOf(String.valueOf(row.get('comision2'))), Regalias__c = Decimal.valueOf(String.valueOf(row.get('regalia'))), Dias_Financiamiento__c = Decimal.valueOf(String.valueOf(row.get('dias'))), ISR_Pct__c = Decimal.valueOf(String.valueOf(row.get('isr'))), RU_Pct__c = Decimal.valueOf(String.valueOf(row.get('ru'))), Clave_Unica__c = q.Id + '_' + anio ); toUpsert.add(pl); } upsert toUpsert Clave_Unica__c;
